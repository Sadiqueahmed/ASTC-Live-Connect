generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Bus {
  id              String            @id
  busNumber       String            @unique
  busType         String            @default("STANDARD")
  capacity        Int               @default(50)
  routeId         String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  BusRoute        BusRoute?         @relation(fields: [routeId], references: [id])
  CommunityReport CommunityReport[]
  LiveBusLocation LiveBusLocation[]
}

model BusRoute {
  id          String    @id
  routeNumber String    @unique
  routeName   String
  startPoint  String
  endPoint    String
  distance    Float
  baseFare    Float
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  Bus         Bus[]
  BusStop     BusStop[]
}

model BusStop {
  id        String   @id
  name      String
  landmark  String?
  latitude  Float
  longitude Float
  sequence  Int
  isMajor   Boolean  @default(false)
  routeId   String
  createdAt DateTime @default(now())
  updatedAt DateTime
  BusRoute  BusRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([routeId, sequence])
}

model CommunityReport {
  id            String       @id
  busId         String?
  reportType    String
  title         String
  description   String
  latitude      Float
  longitude     Float
  trafficZoneId String?
  delayMinutes  Int          @default(0)
  isVerified    Boolean      @default(false)
  helpfulCount  Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime
  TrafficZone   TrafficZone? @relation(fields: [trafficZoneId], references: [id])
  Bus           Bus?         @relation(fields: [busId], references: [id])

  @@index([reportType])
  @@index([createdAt])
}

model LiveBusLocation {
  id            String   @id
  busId         String
  latitude      Float
  longitude     Float
  speed         Float
  heading       Float
  nextStopId    String?
  stopsAway     Int      @default(0)
  currentStatus String   @default("IN_TRANSIT")
  lastUpdated   DateTime @default(now())
  Bus           Bus      @relation(fields: [busId], references: [id], onDelete: Cascade)

  @@index([busId])
}

model TrafficZone {
  id              String            @id
  name            String
  description     String?
  latitude        Float
  longitude       Float
  radiusMeters    Int               @default(500)
  severity        String            @default("MODERATE")
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  CommunityReport CommunityReport[]
}
